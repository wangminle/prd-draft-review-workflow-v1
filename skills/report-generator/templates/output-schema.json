{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report Generator Output",
  "type": "object",
  "required": ["project_name", "files", "summary"],
  "properties": {
    "project_name": {"type": "string"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {"type": "string", "enum": ["markdown", "pdf"]},
          "path": {"type": "string"},
          "size": {"type": "integer"}
        }
      }
    },
    "mermaid_charts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "chart_id": {"type": "string"},
          "code": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_reports", "total_md_size", "chart_count"],
      "properties": {
        "total_reports": {"type": "integer"},
        "total_md_size": {"type": "integer"},
        "chart_count": {"type": "integer"}
      }
    }
  }
}
