# Runtime data — dynamic, clearable (data/code separation)
# Keep README.md and ui-branding.example.yaml as templates; ignore all other runtime data
runtime/*
!runtime/README.md
!runtime/config/
runtime/config/*
!runtime/config/ui-branding.example.yaml
runtime/config/ui-branding.yaml
runtime/config/ui-branding.scan-report.md
# Runtime backups (runtime.bak.* directories created during migration)
runtime.bak.*/

# Python bytecode & cache
**/__pycache__/
*.py[cod]

# Test cache & coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Static analysis caches
.mypy_cache/
.ruff_cache/

# IDE, editor & OS
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store

# Agent / assistant local settings (may contain secrets or machine paths)
.claude/settings.local.json
.claude/*.local.json

# Environment & secrets
.env
.env.*
!.env.example
.venv/

# Logs
*.log

# Distribution & build artifacts
dist/
build/
*.egg-info/
*.egg
*.whl

# Database & pid files (fallback outside runtime/)
*.db
*.db-wal
*.db-shm
*.db-journal
*.sqlite
*.sqlite3
*.pid

# Editor / merge conflict scratch files
*.bak
*.md_[0-9]*

# Node.js dependencies (npm install output)
node_modules/
package-lock.json

# POC-A experiment directory
# Keep scripts, tests and reports in git; ignore samples and results (generated data).
poc-a/*
!poc-a/scripts/
!poc-a/scripts/*.py
!poc-a/tests/
!poc-a/tests/*.py
!poc-a/reports/
!poc-a/reports/*.md

# POC-B experiment directory
poc-b/*
!poc-b/scripts/
!poc-b/scripts/*.py
!poc-b/reports/
!poc-b/reports/*.md

# POC-C experiment directory
poc-c/*
!poc-c/scripts/
!poc-c/scripts/*.py
!poc-c/reports/
!poc-c/reports/*.md

# API keys — never commit
poc-c/openai-key.txt

# P2.D.1 evaluation directory — generated runtime data, results and reports
# Keep the evaluation script and test file in git; ignore runtime data and results
eval/p2d1/runtime/
eval/p2d1/p2d1_results.json
eval/p2d1/P2D1-检索评估报告.md
