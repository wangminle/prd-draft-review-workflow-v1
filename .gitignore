# Runtime data — dynamic, clearable (data/code separation)
# Keep README.md as placeholder, ignore all other runtime data
runtime/*
!runtime/README.md

# Python bytecode & cache
**/__pycache__/
*.py[cod]

# Test cache
.pytest_cache/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment & secrets
.env
.venv/

# Logs
*.log

# Distribution & build artifacts
dist/
*.egg-info/
*.egg
*.whl

# Frontend dependencies (if ever added)
node_modules/