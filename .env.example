# 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM API Keys
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=

# OpenAI-compatible API Base（留空则使用官方 endpoint）
# OPENAI_API_BASE=https://api.openai.com/v1

# Embedding 配置（用于知识库向量检索）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# JWT Secret（生产环境必须修改为随机字符串）
JWT_SECRET=change-this-to-a-random-secret-string

# Server Port（默认 17957）
# SERVER_PORT=17957