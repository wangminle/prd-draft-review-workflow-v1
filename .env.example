# 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM API Keys
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=

# OpenAI-compatible API Base（留空则使用官方 endpoint）
# OPENAI_API_BASE=https://api.openai.com/v1

# Embedding 配置（用于知识库向量检索）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# JWT Secret（必填，至少 32 字符随机串；勿使用示例占位值）
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# 首次启动创建 admin 时可选：显式指定初始密码（否则使用内置预设并告警）
# ADMIN_INITIAL_PASSWORD=

# Server Port（默认 17957）
# SERVER_PORT=17957
